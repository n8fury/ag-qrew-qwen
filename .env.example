# ============================================================
# AG-QREW on Qwen — Environment
# Copy to .env and fill in. NEVER commit .env.
# ============================================================

# --- Alibaba Cloud Model Studio (DashScope), OpenAI-compatible endpoint ---
# The base URL below is the INTERNATIONAL (Singapore) endpoint, so create the key
# in the International Model Studio console (region: Singapore) — a key from the
# mainland Bailian console will NOT authenticate against this endpoint.
#   International console: https://modelstudio.console.alibabacloud.com/  (API Keys → Create)
DASHSCOPE_API_KEY=YOUR_DASHSCOPE_API_KEY
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# --- Model routing (confirm exact current names in Model Studio; they version often) ---
QWEN_MODEL_LEAD=qwen-max          # QA Lead: planning, gap analysis, sign-off reasoning
QWEN_MODEL_WORKER=qwen-plus       # workers: tc-writing, spec generation, API tests
QWEN_MODEL_VISION=qwen-vl-max     # qa-hawk screenshot analysis (multimodal)

# --- Runtime guards (per-agent safety caps) ---
AGENT_MAX_ITERATIONS=25
AGENT_MAX_TOKENS=120000

# --- Browser mode ---
# Leave headless (unset / 0) everywhere headless is required: Docker, ECS, CI —
# they have no display and a headed launch would fail there.
# Set to 1 ONLY for a local demo/video recording to watch the browser drive the app
# (adds slowMo so actions are visible).
PLAYWRIGHT_HEADED=0

# --- Server / dashboard ---
PORT=8787
DEMO_APP_URL=http://localhost:3000

# --- Persistence (inside the shared qa/ volume) ---
DB_PATH=./qa/agqrew.db

# --- Signal bus ---
BUS_PATH=./qa/shared-task-list.txt
