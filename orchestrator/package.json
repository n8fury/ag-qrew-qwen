{
  "name": "ag-qrew-qwen-orchestrator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AG-QREW multi-agent QA runtime on Qwen (Alibaba Cloud Model Studio)",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "run:society": "tsx src/cli.ts --mode society",
    "run:single": "tsx src/cli.ts --mode single",
    "demo:mock": "cross-env AGQREW_MOCK=1 tsx src/mock/runMock.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "openai": "^4.67.0",
    "playwright": "^1.48.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/express": "^5.0.0",
    "@types/node": "^22.7.0",
    "cross-env": "^10.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
