# Secrets — never commit
.env

# Sprint runtime output — all generated per sprint by QA Lead (keep the mount point)
**/qa/**
!**/qa/.gitkeep

# Run archives + logs (local debugging state, e.g. orchestrator/qa-attempt4-*/)
orchestrator/qa-*/
orchestrator/*.log
orchestrator/run*.log

# SQLite databases + WAL sidecars (runtime state; -shm/-wal churn on every open)
*.db
*.db-shm
*.db-wal
# …except the committed sample run — judges read its cases/bugs/disputes without spending tokens
!docs/sample-run/agqrew.db

# Dependencies
node_modules/

# OS
.DS_Store
Thumbs.db
