# Secrets — never commit
.env

# Sprint runtime output — all generated per sprint by QA Lead (keep the mount point)
**/qa/**
!**/qa/.gitkeep

# Run archives + logs (local debugging state, collected under orchestrator/archives/)
orchestrator/archives/
orchestrator/qa-*/
orchestrator/*.log
orchestrator/run*.log

# SQLite databases + WAL sidecars (runtime state; -shm/-wal churn on every open)
*.db
*.db-shm
*.db-wal
# …except the committed sample run — judges read its cases/bugs/disputes without spending tokens
!docs/sample-run/agqrew.db

# Dependencies
node_modules/

# OS
.DS_Store
Thumbs.db

# Internal working docs — kept on disk, out of the public repo
docs/AG-QREW-QWEN-PLAN.pdf
docs/HANDOFF.md
docs/DAY4_CHECKLIST.md
docs/EXECUTION_PLAN.md
docs/UPGRADE_PLAN.md
docs/devpost-draft.md
docs/video-script.md
